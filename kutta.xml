<mujoco model="kutta">

  <!-- ================== COMPILER SETTINGS ================== -->
  <!-- angle: joint limit/range values are in radians -->
  <!-- meshdir: path to the STL mesh files -->
  <!-- autolimits: automatically clamp control signals to actuator limits -->
  <!-- meshdir points to the local assets/ folder (STL files copied alongside this XML) -->
  <compiler angle="radian" meshdir="assets/" autolimits="true"/>

  <!-- ================== SIMULATION OPTIONS ================== -->
  <!-- timestep: integration step in seconds (5 ms is standard for legged robots) -->
  <!-- gravity: 9.81 m/s² downward (negative Z) -->
  <!-- solver: Newton is more accurate for contact-rich locomotion -->
  <!-- iterations/tolerance: balance speed vs. accuracy; 100 iters is robust -->
  <option timestep="0.005" gravity="0 0 -9.81" solver="Newton" iterations="100" tolerance="1e-10"/>

  <!-- ================== DEFAULTS ================== -->
  <!-- Shared properties to avoid repeating them on every geom/joint/actuator. -->
  <default>
    <default class="kutta">
      <!-- Visual geoms: NO collision (mesh), rendered in group 2 -->
      <default class="visual">
        <geom type="mesh" contype="0" conaffinity="0" group="2" density="0"
              rgba="0.79216 0.81961 0.93333 1"/>
      </default>
      <!-- Collision geoms: separate collision primitives (disabled/group 3) -->
      <default class="collision">
        <geom priority="1" condim="6" group="3" contype="0" conaffinity="0"/>
      </default>
      <!-- Sites: small marker for sensors/foot contacts, hidden by default -->
      <site rgba="1 0 0 1" size="0.015" group="5"/>
      <!-- Default joint damping and friction for all revolute joints -->
      <joint damping="0.1" frictionloss="0.01"/>
      <!-- Default position actuator: kp gain, limited to joint range -->
      <position kp="20" forcerange="-10 10"/>
    </default>
  </default>

  <!-- ================== ASSETS ================== -->
  <!-- Declares external STL mesh files used for visual and collision geometry. -->
  <asset>
    <mesh name="base_link" content_type="model/stl" file="base_link.STL"/>
    <mesh name="hip1"      content_type="model/stl" file="hip1.STL"/>
    <mesh name="thigh1"    content_type="model/stl" file="thigh1.STL"/>
    <mesh name="knee1"     content_type="model/stl" file="knee1.STL"/>
    <mesh name="hip2"      content_type="model/stl" file="hip2.STL"/>
    <mesh name="thigh2"    content_type="model/stl" file="thigh2.STL"/>
    <mesh name="knee2"     content_type="model/stl" file="knee2.STL"/>
    <mesh name="hip3"      content_type="model/stl" file="hip3.STL"/>
    <mesh name="thigh3"    content_type="model/stl" file="thigh3.STL"/>
    <mesh name="knee3"     content_type="model/stl" file="knee3.STL"/>
    <mesh name="hip4"      content_type="model/stl" file="hip4.STL"/>
    <mesh name="thigh4"    content_type="model/stl" file="thigh4.STL"/>
    <mesh name="knee4"     content_type="model/stl" file="knee4.STL"/>
  </asset>

  <!-- ================== WORLD BODY ================== -->
  <!-- The simulation kinematic tree. All bodies, joints, and geoms live here. -->
  <worldbody>

    <!-- ================== GROUND PLANE ================== -->
    <!-- Infinite flat floor at z=0. condim=3 enables friction (tangential forces).  -->
    <!-- friction="1 0.005 0.0001": sliding, torsional, rolling coefficients.        -->
    <!-- contype/conaffinity=1 so it collides with the knee meshes (contype=1).       -->
    <geom name="floor" type="plane" size="0 0 1" pos="0 0 0"
          rgba="0.6 0.6 0.6 1" condim="3" friction="1 0.005 0.0001"
          contype="1" conaffinity="1"/>

    <!-- ================== BASE LINK (Main Torso) ================== -->
    <!-- spawn height 0.35 m: with all joints at 0, feet sit ~0.18 m above floor    -->
    <!-- so the robot settles to standing after ~0.2 s of free fall.                 -->
    <body name="base_link" pos="0 0 0.35" childclass="kutta">

      <!-- freejoint: allows the base to translate and rotate freely in 3D (6-DoF). -->
      <!-- Without this the robot is fixed to the world. -->
      <freejoint name="floating_base"/>

      <!-- Inertial properties of the main chassis.                               -->
      <!-- mass ~1.2 kg (approximate; tune to your real robot).                   -->
      <inertial pos="0 0 0" mass="1.2" diaginertia="0.012 0.025 0.030"/>

      <!-- Visual geometry (mesh collision) -->
      <geom name="base_link" mesh="base_link" class="visual"/>

      <!-- IMU site: located roughly at the center of the torso.                  -->
      <!-- Sensors below reference this site.                                     -->
      <site name="imu" pos="0 0 0" class="kutta"/>

      <!-- ================== LEG 1 (Front-Left) ================== -->
      <!-- pos: attachment point on the torso — do NOT edit (from original URDF). -->
      <body name="hip1" pos="0.199 0.14 0.083">
        <inertial pos="-0.0541 -0.0032112 3.7763e-05"
                  quat="0.710984 -0.0101736 -0.0137251 0.703001"
                  mass="0.17061" diaginertia="0.000125726 8.87391e-05 7.9306e-05"/>
        <!-- revolute1: abduction/adduction (X-axis) -->
        <joint name="revolute1" pos="0 0 0" axis="1 0 0" range="-3.14 3.14" actuatorfrcrange="-10 10"/>
        <geom name="hip1" mesh="hip1" class="visual"/>

        <body name="thigh1" pos="-0.06295 0.09625 -5.7702e-05">
          <inertial pos="-0.043844 -0.024483 -0.032581"
                    quat="0.628507 0.311638 0.322239 0.635628"
                    mass="0.41837" diaginertia="0.00127605 0.00117315 0.000175136"/>
          <!-- revolute2: hip flexion/extension (Y-axis) -->
          <joint name="revolute2" pos="0 0 0" axis="0 1 0" range="-3.14 3.14" actuatorfrcrange="-10 10"/>
          <geom name="thigh1" mesh="thigh1" class="visual"/>

          <body name="knee1" pos="-0.17634 -0.0095 -0.13155">
            <inertial pos="0.10909 0.0040043 -0.063464"
                      quat="0.352996 0.613161 0.612693 0.352184"
                      mass="0.11838" diaginertia="0.000418161 0.000407576 1.51933e-05"/>
            <!-- revolute3: knee flexion (negative Y-axis) -->
            <joint name="revolute3" pos="0 0 0" axis="0 -1 0" range="-3.14 3.14" actuatorfrcrange="-10 10"/>
            <geom name="knee1" mesh="knee1" class="visual" contype="1" conaffinity="1"/>
            <!-- Foot contact site at the tip of the lower leg -->
            <site name="FL" pos="0.20 0 -0.12" class="kutta"/>
          </body>
        </body>
      </body>

      <!-- ================== LEG 2 (Rear-Left) ================== -->
      <body name="hip2" pos="-0.221 0.14 0.083">
        <inertial pos="-0.0541 -0.0032112 3.7763e-05"
                  quat="0.710984 -0.0101736 -0.0137251 0.703001"
                  mass="0.17061" diaginertia="0.000125726 8.87391e-05 7.9306e-05"/>
        <joint name="revolute4" pos="0 0 0" axis="1 0 0" range="-3.14 3.14" actuatorfrcrange="-10 10"/>
        <geom name="hip2" mesh="hip2" class="visual"/>

        <body name="thigh2" pos="-0.06295 0.09625 -5.7702e-05">
          <inertial pos="-0.043844 -0.024483 -0.032581"
                    quat="0.628507 0.311638 0.322239 0.635628"
                    mass="0.41837" diaginertia="0.00127605 0.00117315 0.000175136"/>
          <joint name="revolute5" pos="0 0 0" axis="0 1 0" range="-3.14 3.14" actuatorfrcrange="-10 10"/>
          <geom name="thigh2" mesh="thigh2" class="visual"/>

          <body name="knee2" pos="-0.17634 -0.0095 -0.13155">
            <inertial pos="0.10909 0.0040043 -0.063464"
                      quat="0.352996 0.613161 0.612693 0.352184"
                      mass="0.11838" diaginertia="0.000418161 0.000407576 1.51933e-05"/>
            <joint name="revolute6" pos="0 0 0" axis="0 -1 0" range="-3.14 3.14" actuatorfrcrange="-10 10"/>
            <geom name="knee2" mesh="knee2" class="visual" contype="1" conaffinity="1"/>
            <site name="RL" pos="0.20 0 -0.12" class="kutta"/>
          </body>
        </body>
      </body>

      <!-- ================== LEG 3 (Front-Right) ================== -->
      <body name="hip3" pos="0.199 -0.14 0.083">
        <inertial pos="-0.0541 0.0032112 3.7763e-05"
                  quat="0.703001 -0.0137251 -0.0101736 0.710984"
                  mass="0.17061" diaginertia="0.000125726 8.87391e-05 7.9306e-05"/>
        <joint name="revolute7" pos="0 0 0" axis="1 0 0" range="-3.14 3.14" actuatorfrcrange="-10 10"/>
        <geom name="hip3" mesh="hip3" class="visual"/>

        <body name="thigh3" pos="-0.06295 -0.09625 -5.7702e-05">
          <inertial pos="-0.043844 0.024483 -0.032581"
                    quat="0.635628 0.322239 0.311638 0.628507"
                    mass="0.41837" diaginertia="0.00127605 0.00117315 0.000175136"/>
          <joint name="revolute8" pos="0 0 0" axis="0 -1 0" range="-3.14 3.14" actuatorfrcrange="-10 10"/>
          <geom name="thigh3" mesh="thigh3" class="visual"/>

          <body name="knee3" pos="-0.17634 0.0095 -0.13155">
            <inertial pos="0.10909 -0.0040043 -0.063464"
                      quat="0.352184 0.612693 0.613161 0.352996"
                      mass="0.11838" diaginertia="0.000418161 0.000407576 1.51933e-05"/>
            <joint name="revolute9" pos="0 0 0" axis="0 1 0" range="-3.14 3.14" actuatorfrcrange="-10 10"/>
            <geom name="knee3" mesh="knee3" class="visual" contype="1" conaffinity="1"/>
            <site name="FR" pos="0.20 0 -0.12" class="kutta"/>
          </body>
        </body>
      </body>

      <!-- ================== LEG 4 (Rear-Right) ================== -->
      <body name="hip4" pos="-0.221 -0.14 0.083">
        <inertial pos="-0.0541 0.0032112 3.7763e-05"
                  quat="0.703001 -0.0137251 -0.0101736 0.710984"
                  mass="0.17061" diaginertia="0.000125726 8.87391e-05 7.9306e-05"/>
        <joint name="revolute10" pos="0 0 0" axis="1 0 0" range="-3.14 3.14" actuatorfrcrange="-10 10"/>
        <geom name="hip4" mesh="hip4" class="visual"/>

        <body name="thigh4" pos="-0.06295 -0.09625 -5.7702e-05">
          <inertial pos="-0.043844 0.024483 -0.032581"
                    quat="0.635628 0.322239 0.311638 0.628507"
                    mass="0.41837" diaginertia="0.00127605 0.00117315 0.000175136"/>
          <joint name="revolute11" pos="0 0 0" axis="0 -1 0" range="-3.14 3.14" actuatorfrcrange="-10 10"/>
          <geom name="thigh4" mesh="thigh4" class="visual"/>

          <body name="knee4" pos="-0.17634 0.0095 -0.13155">
            <inertial pos="0.10909 -0.0040043 -0.063464"
                      quat="0.352184 0.612693 0.613161 0.352996"
                      mass="0.11838" diaginertia="0.000418161 0.000407576 1.51933e-05"/>
            <joint name="revolute12" pos="0 0 0" axis="0 1 0" range="-3.14 3.14" actuatorfrcrange="-10 10"/>
            <geom name="knee4" mesh="knee4" class="visual" contype="1" conaffinity="1"/>
            <site name="RR" pos="0.20 0 -0.12" class="kutta"/>
          </body>
        </body>
      </body>

    </body>
  </worldbody>

  <!-- ================== ACTUATORS ================== -->
  <!-- Position actuators (PD-like) for each of the 12 revolute joints.          -->
  <!-- kp: proportional gain. forcerange: max torque (N·m). ctrlrange: joint lim. -->
  <!-- Leg 1 (Front-Left) -->
  <actuator>
    <position name="act_revolute1"  joint="revolute1"  kp="20" forcerange="-10 10" ctrlrange="-3.14 3.14"/>
    <position name="act_revolute2"  joint="revolute2"  kp="20" forcerange="-10 10" ctrlrange="-3.14 3.14"/>
    <position name="act_revolute3"  joint="revolute3"  kp="20" forcerange="-10 10" ctrlrange="-3.14 3.14"/>
    <!-- Leg 2 (Rear-Left) -->
    <position name="act_revolute4"  joint="revolute4"  kp="20" forcerange="-10 10" ctrlrange="-3.14 3.14"/>
    <position name="act_revolute5"  joint="revolute5"  kp="20" forcerange="-10 10" ctrlrange="-3.14 3.14"/>
    <position name="act_revolute6"  joint="revolute6"  kp="20" forcerange="-10 10" ctrlrange="-3.14 3.14"/>
    <!-- Leg 3 (Front-Right) -->
    <position name="act_revolute7"  joint="revolute7"  kp="20" forcerange="-10 10" ctrlrange="-3.14 3.14"/>
    <position name="act_revolute8"  joint="revolute8"  kp="20" forcerange="-10 10" ctrlrange="-3.14 3.14"/>
    <position name="act_revolute9"  joint="revolute9"  kp="20" forcerange="-10 10" ctrlrange="-3.14 3.14"/>
    <!-- Leg 4 (Rear-Right) -->
    <position name="act_revolute10" joint="revolute10" kp="20" forcerange="-10 10" ctrlrange="-3.14 3.14"/>
    <position name="act_revolute11" joint="revolute11" kp="20" forcerange="-10 10" ctrlrange="-3.14 3.14"/>
    <position name="act_revolute12" joint="revolute12" kp="20" forcerange="-10 10" ctrlrange="-3.14 3.14"/>
  </actuator>

  <!-- ================== SENSORS ================== -->
  <!-- IMU sensors (attached to the 'imu' site on the base body):                -->
  <!--   gyro        → angular velocity (rad/s)                                  -->
  <!--   velocimeter → linear velocity  (m/s)                                    -->
  <!--   accelerometer → linear acceleration (m/s²)                              -->
  <!-- Joint sensors for proprioception:                                          -->
  <!--   jointpos → joint angle (rad)                                             -->
  <!--   jointvel → joint angular velocity (rad/s)                               -->
  <!--   actuatorfrc → joint torque (N·m)                                         -->
  <!-- Foot contact sensors via touch sensors at each foot site.                  -->
  <!-- subtreeangmom: total angular momentum of the base subtree (for rewards).   -->
  <sensor>
    <!-- IMU -->
    <gyro         name="imu_ang_vel"  site="imu"/>
    <velocimeter  name="imu_lin_vel"  site="imu"/>
    <accelerometer name="imu_lin_acc" site="imu"/>
    <subtreeangmom name="root_angmom" body="base_link"/>

    <!-- Joint position (proprioception) -->
    <jointpos name="q_revolute1"  joint="revolute1"/>
    <jointpos name="q_revolute2"  joint="revolute2"/>
    <jointpos name="q_revolute3"  joint="revolute3"/>
    <jointpos name="q_revolute4"  joint="revolute4"/>
    <jointpos name="q_revolute5"  joint="revolute5"/>
    <jointpos name="q_revolute6"  joint="revolute6"/>
    <jointpos name="q_revolute7"  joint="revolute7"/>
    <jointpos name="q_revolute8"  joint="revolute8"/>
    <jointpos name="q_revolute9"  joint="revolute9"/>
    <jointpos name="q_revolute10" joint="revolute10"/>
    <jointpos name="q_revolute11" joint="revolute11"/>
    <jointpos name="q_revolute12" joint="revolute12"/>

    <!-- Joint velocity -->
    <jointvel name="dq_revolute1"  joint="revolute1"/>
    <jointvel name="dq_revolute2"  joint="revolute2"/>
    <jointvel name="dq_revolute3"  joint="revolute3"/>
    <jointvel name="dq_revolute4"  joint="revolute4"/>
    <jointvel name="dq_revolute5"  joint="revolute5"/>
    <jointvel name="dq_revolute6"  joint="revolute6"/>
    <jointvel name="dq_revolute7"  joint="revolute7"/>
    <jointvel name="dq_revolute8"  joint="revolute8"/>
    <jointvel name="dq_revolute9"  joint="revolute9"/>
    <jointvel name="dq_revolute10" joint="revolute10"/>
    <jointvel name="dq_revolute11" joint="revolute11"/>
    <jointvel name="dq_revolute12" joint="revolute12"/>

    <!-- Actuator force (torque feedback) -->
    <actuatorfrc name="tau_revolute1"  actuator="act_revolute1"  noise="0.001"/>
    <actuatorfrc name="tau_revolute2"  actuator="act_revolute2"  noise="0.001"/>
    <actuatorfrc name="tau_revolute3"  actuator="act_revolute3"  noise="0.001"/>
    <actuatorfrc name="tau_revolute4"  actuator="act_revolute4"  noise="0.001"/>
    <actuatorfrc name="tau_revolute5"  actuator="act_revolute5"  noise="0.001"/>
    <actuatorfrc name="tau_revolute6"  actuator="act_revolute6"  noise="0.001"/>
    <actuatorfrc name="tau_revolute7"  actuator="act_revolute7"  noise="0.001"/>
    <actuatorfrc name="tau_revolute8"  actuator="act_revolute8"  noise="0.001"/>
    <actuatorfrc name="tau_revolute9"  actuator="act_revolute9"  noise="0.001"/>
    <actuatorfrc name="tau_revolute10" actuator="act_revolute10" noise="0.001"/>
    <actuatorfrc name="tau_revolute11" actuator="act_revolute11" noise="0.001"/>
    <actuatorfrc name="tau_revolute12" actuator="act_revolute12" noise="0.001"/>

    <!-- Foot contact forces (touch sensors at foot sites) -->
    <touch name="contact_FL" site="FL"/>
    <touch name="contact_RL" site="RL"/>
    <touch name="contact_FR" site="FR"/>
    <touch name="contact_RR" site="RR"/>
  </sensor>

</mujoco>